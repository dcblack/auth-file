#!/usr/bin/env bash
#
#$Info: randlist - Pseudo-randomize a list of words using a seed. $
#$Syntax: randlist [--seed=NUM] WORD1 WORD2 ... $
# Seed default: 1. Negative seed does no sorting. Seed of 0 uses /dev/urandom.

function Randlist() {
  local VERSION=1.0

  set -euo pipefail

  local SEED=1 TYPE="default"
  local -a WORDS=()
  local LOG=""

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      echo '
Name
----

randlist - Pseudo-randomize a list of words using a seed.

Synopsis
--------

```bash
randlist --help|-h
randlist --version
randlist [--seed=NUM] [--seed-file=FILE] "WORD1" "WORD2" ... $
randlist [--seed=NUM] [--seed-file=FILE] TEXT_FILE
```

Seed default: 1. Seed of 0 uses /dev/urandom. Negative seed does no sorting.
Text file will use each lines as a "WORD".

'
      return 0
      ;;
    --version)
      echo "$0 ${VERSION}"
      return 0
      ;;
    --seed=*)
      TYPE="specified"
      SEED="${1#--seed=}"
      shift
      ;;
    -s)
      if [[ $# -lt 2 ]]; then
        echo "Error: -s requires a value" >&2
        return 1
      fi
      TYPE="specified"
      SEED="$2"
      shift 2
      ;;
    --seed-file=*)
      LOG="$2"
      shift
      ;;
    -*)
      echo "Error: Unknown option $1" >&2
      return 1
      ;;
    *)
      WORDS+=("$1")
      shift
      ;;
    esac
  done

  if [[ ${#WORDS[@]} -eq 0 ]]; then
    echo -n "[1;91m"
    echo "Usage: randlist [--seed=NUM] WORD1 WORD2 ..." >&2
    echo "    or randlist --help" >&2
    echo -n "[0m"
    return 1
  elif [[ ${#WORDS[@]} -eq 1 ]]; then
    if [[ -r "${WORDS[0]}"  && -f "${WORDS[0]}" ]]; then
      local -a LINES=()
      local line
      while IFS= read -r line || [[ -n "${line}" ]]; do
          LINES+=("${line}")
      done < "filename.txt"   
      WORDS=("${LINES[@]}")
    elif [[ -e "${WORDS[0]}" ]]; then
      echo -n "[1;91mError: unreadable file ${WORDS[0]}[0m"
      return 1
    else
      echo "${WORDS[0]}"
      echo "[1;96mInfo:[0m one element" >/dev/tty
      return 0
    fi
  fi

  # Initialize RANDOM with seed
  if [[ "${SEED}" -lt 0 ]]; then
    TYPE="unchanged"
    printf '%s\n' "${WORDS[@]}"
    echo "[1;96mInfo:[0m original order" >/dev/tty
    return 0
  elif [[ "${SEED}" -eq 0 ]]; then
    # Use TRNG (True Random Number Generator) via /dev/urandom
    # Read 4 bytes (32 bits) and convert to decimal
    TYPE="TRNG"
    SEED=$(od -An -t u4 -N 4 </dev/urandom | tr -d ' ')
    RANDOM="${SEED}"
  else
    RANDOM="${SEED}"
  fi

  # Fisher-Yates shuffle
  n=${#WORDS[@]}
  for ((i = n - 1; i > 0; i--)); do
    # Generate random index between 0 and i
    j=$((RANDOM % (i + 1)))
    # Swap elements
    temp="${WORDS[i]}"
    WORDS[i]="${WORDS[j]}"
    WORDS[j]="${temp}"
  done

  # Output shuffled words
  printf '%s\n' "${WORDS[@]}"
  printf "[1;96mInfo:[0m Seed %s\n" "${SEED}" >/dev/tty
  if [[ -n "${LOG}" ]]; then
    if ! echo "${SEED}" >"${LOG}"; then
      printf "[1;96mError: Unable to write seed file[0m '%s'\n" "${LOG}"
      return 1
    fi
    printf "[1;96mInfo:[0m Seed saved in '%s'\n" "${LOG}" >/dev/tty
  fi
}

Randlist "$@"
