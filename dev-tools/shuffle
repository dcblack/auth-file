#!/usr/bin/env bash
#
#$Info: shuffle - Randomly shuffle a list of words using a seed. $
# See HELP_TEXT for more information

function Report_error() {
  printf "[1;96mError:[0m %s\n" "$*" 1>&2
  return 1
}

function Record-seed() {
  local VERBOSE=0
  if [[ "$1" == '--verbose' ]]; then
    VERBOSE=1
    shift
  fi
  local SEED="$1" TYPE="$2" SAVE_FILE="$3"
  if [[ ${VERBOSE} == 1 ]]; then
    printf "[1;96mInfo:[0m Seed %s %s\n" "${SEED}" "${TYPE}" >/dev/tty
  fi
  if [[ -n "${SAVE_FILE}" ]]; then
    if ! echo -n '# ' >"${SAVE_FILE}"; then
      Report_error "Unable to write seed file '%s'"
    fi
    {
      date
      printf "# %s\n" "${TYPE}"
      printf "%s\n" "${SEED}"
    } >>"${SAVE_FILE}"
    if [[ ${VERBOSE} == 1 ]]; then
      printf "[1;96mInfo:[0m Seed saved in '%s'\n" "${SAVE_FILE}" >/dev/tty
    fi
  fi
}

function Shuffle() {
  local VERSION=1.0 HELP_TEXT='
Name
----

shuffle - Randomly shuffle a list of words using a seed.

Synopsis
--------

```bash
shuffle --help|-h
shuffle --version
shuffle [OPTIONS] "WORD1" "WORD2" ... $
shuffle [OPTIONS] TEXT_FILE
```
Options
-------

Option       | Description
------       | -----------
--help       | displays this text and exits (aka -h)
--version    | displays the version and exits
--seed=NUM   | specifies the starting seed (aka -s NUM)
--seed=FILE  | specifies the starting seed (aka -s NUM)
--save=FILE  | specifies a file to dump the seed information into
--stdin      | allows piping the words one line at a time from stdin
--verbose|-v | echoes info

Notes
-----

Seed default: 1. Seed of 0 uses /dev/urandom. Negative seed does no sorting.

Text file will use each lines as a "WORD".

If --stdin is intermixed with the WORDs, it will interpolate at that point.

'

  set -euo pipefail

  local SEED=1 TYPE="Default seed"
  local -a WORDS=()
  local ARG="" SAVE_FILE="" line  VERBOSE=0

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    ARG="$1"
    shift
    case "${ARG}" in
    --help | -h)
      echo "${HELP_TEXT}"
      return 0
      ;;

    --version)
      echo "$0 ${VERSION}"
      return 0
      ;;

    --verbose | -v)
      VERBOSE=1
      ;;

    --save=*)
      SAVE_FILE="${ARG/*=/}"
      ;;

    --seed=*)
      ARG="${ARG/*=/}"
      if [[ "${ARG}" =~ ^-?[0-9]+$ ]]; then
        SEED="${ARG}"
      elif [[ -r "${ARG}" && -f "${ARG}" ]]; then
        local filename="${ARG}"
        while IFS= read -r line || [[ -n "${line}" ]]; do
          if [[ "${line}" =~ ^[0-9]+$ ]]; then
            SEED="${line}"
            break
          fi
        done <"${filename}"
      else
        Report_error "Undecipherable seed -- see $0 --help"
        return 1
      fi
      TYPE="User specified seed ${SEED}"
      ;;

    -s)
      if [[ $# -lt 1 ]]; then
        Report_error " -s requires a value"
        return 1
      fi
      ARG="$1"
      shift
      if [[ "${ARG}" =~ ^-?[0-9]+$ ]]; then
        SEED="${ARG}"
      elif [[ -r "${ARG}" ]]; then
        local filename="${ARG}"
        while IFS= read -r line || [[ -n "${line}" ]]; do
          if [[ "${line}" =~ ^[0-9]+$ ]]; then
            SEED="${line}"
            break
          fi
        done <"${filename}"
      else
        Report_error "Undecipherable seed -- see $0 --help"
        return 1
      fi
      TYPE="User specified seed ${SEED}"
      ;;

    --stdin)
      if [[ ! -t 0 ]] && read -t 0; then
        # Consume all stdin safely
        while IFS= read -r line; do
          WORDS+=("${line}")
        done
      else
        Report_error "-stdin specified but no data piped."
        return 1
      fi
      ;;

    -*)
      Report_error "Unknown option '${ARG}'"
      return 1
      ;;

    *)
      WORDS+=("${ARG}")
      ;;

    esac
  done

  if [[ ${#WORDS[@]} -eq 0 ]]; then
    echo -n "[1;91m"
    echo "Usage: shuffle [--seed=NUM] WORD1 WORD2 ..." >&2
    echo "    or shuffle --help" >&2
    echo -n "[0m"
    return 1
  elif [[ ${#WORDS[@]} -eq 1 ]]; then
    if [[ -r "${WORDS[0]}" && -f "${WORDS[0]}" ]]; then
      local filename="${WORDS[0]}"
      local -a LINES=()
      while IFS= read -r line || [[ -n "${line}" ]]; do
        LINES+=("${line}")
      done <"${filename}"
      WORDS=("${LINES[@]}")
    elif [[ -e "${WORDS[0]}" ]]; then
      Report_error "Unreadable file '${WORDS[0]}'"
      return 1
    else
      echo "${WORDS[0]}"
      echo "[1;96mInfo:[0m one element" >/dev/tty
      if [[ ${VERBOSE} == 1 ]]; then
        Record-seed --verbose "${SEED}" "${TYPE}" "${SAVE_FILE}"
      else
        Record-seed "${SEED}" "${TYPE}" "${SAVE_FILE}"
      fi
      return 0
    fi
  fi

  # Initialize RANDOM with seed
  if [[ ${SEED} -lt 0 ]]; then
    TYPE="${TYPE} as unchanged"
    printf '%s\n' "${WORDS[@]}"
    echo "[1;96mInfo:[0m original order" >/dev/tty
    if [[ ${VERBOSE} == 1 ]]; then
      Record-seed --verbose "${SEED}" "${TYPE}" "${SAVE_FILE}"
    else 
      Record-seed "${SEED}" "${TYPE}" "${SAVE_FILE}"
    fi
    return 0
  elif [[ ${SEED} -eq 0 ]]; then
    # Use TRNG (True Random Number Generator) via /dev/urandom
    # Read 4 bytes (32 bits) and convert to decimal
    TYPE="${TYPE} is true random"
    SEED=$(od -An -t u4 -N 4 </dev/urandom | tr -d ' ')
    RANDOM="${SEED}"
  else
    RANDOM="${SEED}"
  fi

  # Fisher-Yates shuffle
  n=${#WORDS[@]}
  for ((i = n - 1; i > 0; i--)); do
    # Generate random index between 0 and i
    j=$((RANDOM % (i + 1)))
    # Swap elements
    temp="${WORDS[i]}"
    WORDS[i]="${WORDS[j]}"
    WORDS[j]="${temp}"
  done

  # Output shuffled words
  printf '%s\n' "${WORDS[@]}"
  if [[ ${VERBOSE} == 1 ]]; then
    Record-seed --verbose "${SEED}" "${TYPE}" "${SAVE_FILE}"
  else
    Record-seed "${SEED}" "${TYPE}" "${SAVE_FILE}"
  fi
}

Shuffle "$@"
