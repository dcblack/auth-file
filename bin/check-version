#!/usr/bin/env bash
#
#$Info: check-version - verify version syntax and expand as needed. $

# shellcheck disable=SC2312,SC2034

function Check-version()
{
  SYNTAX='
Name
----

check-version - verify version syntax and expand as needed.

Synopsis
--------

```bash
check-version [OPTIONS] VERSION [MESSAGE ARGS]
```

Message arguments are simply echoed back.

| Option       | Description                                          |
| ------------ | ---------------------------------------------------- |
| --help       | Display this text                                    |
| --use-dots   | Output the result in dotted form (default is dashes) |
| --no-message | Suppress anything other than the version             |
| --silent     | Suppress all messages (i.e., return code only)       |
| --verbose    | More messages                                        |

Description
-----------

Examines the supplied version number and expands if necessary to the standard tuple of MAJOR-MINOR-PATCH.
Obtains the largest git tag matching v#.#.#, which is considered the current version.
Compares the supplied version to the current version and returns an error if there is not a strict advance in the version number.
If comparison passed, display the full formatted version with two possibilites. Either use hyphens (default) or dots.

'

  export NOCOLOR
  local RED="[91;1m" GRN="[92;1m" YLW="[93;1m" BLU="[94;1m" CYN="[96;1m" MAG="[95;1m" OFF="[0m"
  if [[ ${NOCOLOR} == 1 ]]; then
    RED="" GRN="" YLW="" BLU="" CYN="" MAG="" OFF=""
  fi

  export DEBUGGING=0
  local INCOMING_VERS="" USE_DOTS=0 NO_MESSAGE=0 SILENT=0 SHOW=0 VERBOSE=0
  while [[ "$1" =~ ^- ]]; do
    case "$1" in
      -h | --help)
        if command -v glow 1>/dev/null; then
          printf "%s\n" "${SYNTAX}" | glow -p
        elif command -v less 1>/dev/null; then
          printf "%s\n" "${SYNTAX}" | less
        elif command -v more 1>/dev/null; then
          printf "%s\n" "${SYNTAX}" | more
        else
          printf "%s\n" "${SYNTAX}"
        fi
        return 0
        ;;
      --debug)
        DEBUGGING=1
        ;;
      --use-dots)
        USE_DOTS=1
        ;;
      --no-message | -nm)
        NO_MESSAGE=1
        ;;
      --show)
        SHOW=1
        set 999.0.0
        ;;
      --silent | -s)
        SILENT=1
        ;;
      --verbose | -v)
        VERBOSE=1
        ;;
      *)
        printf "%sWarning:%s unknown option '%s' - ignoring\n" "${YLW}" "${OFF}" "$1" 1>&2
        return 1
        ;;
    esac
    shift
  done

  # Current version
  local -a CURRENT_TUPLE=()
  local MAJOR=0 MINOR=0 PATCH=0 CURRENT_VERS
  read -r -a CURRENT_TUPLE <<< "$(git tag --list | sort | grep '^v' | tail -1)" #>>>
  if [[ "${#CURRENT_TUPLE[@]}" == 1 ]]; then
    CURRENT_VERS="${CURRENT_TUPLE[0]/v}"
    IFS=. read -ra CURRENT_TUPLE <<< "${CURRENT_VERS}" #>>>
    for i in {0..2}; do
      case ${i} in
        0) MAJOR="${CURRENT_TUPLE[${i}]}" ;;
        1) MINOR="${CURRENT_TUPLE[${i}]}" ;;
        2) PATCH="${CURRENT_TUPLE[${i}]}" ;;
        *) ;;
      esac
    done
  fi

  local GIT_ROOT NAME_SCRIPT TOOL_NAME VERS_SCRIPT SOURCE_VERS
  GIT_ROOT="$(git rev-parse --show-toplevel)"
  # shellcheck disable=SC2016
  NAME_SCRIPT='$name=$1 if m{^name = "([^"]+)"}; END{print $name}'
  TOOL_NAME="$(perl -lne "${NAME_SCRIPT}" "${GIT_ROOT}/Cargo.toml")"
  # shellcheck disable=SC2016
  VERS_SCRIPT='$vers=$1 if m{^version = "([^"]+)"} and $vers !~ m{[[:digit:]]} ; END{print $vers}'
  SOURCE_VERS="$(perl -lne "${VERS_SCRIPT}" "${GIT_ROOT}/Cargo.toml")"
  
  INCOMING_VERS="$1"
  if [[ $# == 0 || "$1" =~ ^[^0-9] ]]; then
    INCOMING_VERS="${SOURCE_VERS}"
    set "ignore" "$@"
  fi
  shift
  INCOMING_VERS="${INCOMING_VERS//./-}"

  # Test arguments
  if [[ "${INCOMING_VERS}" =~ ^[0-9]+-[0-9]+-[0-9]+$ ]]; then
    # nothing to do
    echo -n ''
  elif [[ "${INCOMING_VERS}" =~ ^[0-9]+-[0-9]$ ]]; then
    INCOMING_VERS="${MAJOR}-${INCOMING_VERS}"
  elif [[ "${INCOMING_VERS}" =~ ^[0-9]+$ ]]; then
    INCOMING_VERS="${MAJOR}-${INCOMING_VERS}-${PATCH}"
  else
    printf "%sError:%s '${INCOMING_VERS}' does not match [:digit:]+([-.][:digit:]+){1,3}\n" "${RED}" "${OFF}" 1>&2
    return 1
  fi

  if [[ ${SHOW} == 1 || ${VERBOSE} == 1 ]]; then
    printf "[1;92mBinary tool name    %s[0m\n" "${TOOL_NAME}"
    printf "[1;92mCurrent tag version %s[0m\n" "${CURRENT_VERS}"
    printf "[1;92mSource code version %s[0m\n" "${SOURCE_VERS}"
    printf "[1;92mSpecified   version %s[0m\n" "${INCOMING_VERS//-/.}"
    if [[ ${SHOW} == 1 ]]; then
      return 0
    fi
  fi

  local GE
  GE="$(Compare_versions "${INCOMING_VERS//-/.}" "${CURRENT_VERS//-/.}")"
  case "${GE}" in
    1) ;;
    *) printf "%sError:%s Specified version %s must be greater than current version %s\n" "${RED}" "${OFF}" "${INCOMING_VERS}" "${CURRENT_VERS}" 1>&2
       return 1
       ;;
  esac

  if [[ ${USE_DOTS} == 0 ]]; then
    INCOMING_VERS="${INCOMING_VERS//./-}"
  else
    INCOMING_VERS="${INCOMING_VERS//-/.}"
  fi

  if [[ ${SILENT} == 0 ]]; then
    if [[ $# -gt 0 && ${NO_MESSAGE} == 0 ]]; then
      echo "${INCOMING_VERS}" "$*"
    else
      echo "${INCOMING_VERS}"
    fi
  fi
}

function Compare_versions() {
  local v1 v2
  IFS=. read -ra v1 <<< "$1" #>>>
  IFS=. read -ra v2 <<< "$2" #>>>
  for i in {0..2}; do
    if (( v1[i] > v2[i] )); then
      echo 1  # VAR1 > VAR2
      return
    elif (( v1[i] < v2[i] )); then
      echo -1  # VAR1 < VAR2
      return
    fi
  done
  echo 0  # Equal
}

function Debug() {
  export NOCOLOR DEBUGGING
  if [[ ${DEBUGGING} != 1 ]]; then return; fi
  local RED="[91;1m" GRN="[92;1m" YLW="[93;1m" BLU="[94;1m" CYN="[96;1m" MAG="[95;1m" OFF="[0m"
  if [[ ${NOCOLOR} == 1 ]]; then
    RED="" GRN="" YLW="" BLU="" CYN="" MAG="" OFF=""
  fi
  printf "%sDebug:%s %s\n" "${MAG}" "${OFF}" "$*"

}

Check-version "$@"
