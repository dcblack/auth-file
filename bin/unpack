#!/usr/bin/env bash
#
#$Info: unpack - Unpacks zip files from chatGPT stored in ARCHIVE to proper locations. $

function Unpack()
{
  if [[ $# -lt 1 ]]; then
    echo "Syntax: unpack VERSION"
    exit 1
  fi

  local v=""
  if check-version "$1"; then
    v="$(check-version "$1")"
  else
    return 1
  fi

  local GIT_WORK_DIR=""
  if git rev-parse --show-toplevel 1>/dev/null 2>&1; then
    # shellcheck disable=SC2034
    GIT_WORK_DIR="$(git rev-parse --show-toplevel)"
  else
    echo "Error: must be inside git repo" 1>&2
    return 1
  fi

  local ARCHIVE_DIR="${GIT_WORK_DIR}/ARCHIVE"
  if cd "${ARCHIVE_DIR}"; then
    echo '[1;96mEntered archive[0m';
  else
    echo "Error: Missing directory ${ARCHIVE_DIR}" 1>&2
    return 1
  fi

  header "${v}"
  for f in *"${v}"*.zip; do
    d="${f/.zip/}";
    unzip "${f}";
    if [[ "${f}" =~ .+-rust-v[0-9]-[0-9]-[0-9].zip$ ]]; then
      rsync --exclude-from=../.gitignore -av "${d}"/ ../;
    else
      printf "[1;91m";
      mv "${d}".md ../NOTES/ && printf "[92mSaved note %s" "${d}";
      printf "[0m\n";
    fi;
    rm -fr "${d}";
  done
  printf "[96;1mUnpacked %s[0m\n" "${v}"
}

Unpack "$@"

